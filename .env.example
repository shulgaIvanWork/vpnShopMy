# ==========================================
# MAX VPN Bot - Environment Configuration
# ==========================================
# Скопируйте этот файл в .env и заполните значения

# MAX Bot API Configuration
MAX_BOT_TOKEN=your_max_bot_token_here
MAX_BOT_USERNAME=@your_bot_username
BOT_ADMINS=53530798

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=vpn_user
DB_PASSWORD=your_secure_password_here
DB_NAME=vpnbot

# 3X-UI Panel Configuration (JSON Array)
# Формат: [{"url":"http(s)://server:port/path","username":"admin","password":"pass","name":"ServerName","inboundId":1,"maxClients":200,"subdomain":"vpn.example.com"}]
# subdomain - опционально, используется для HTTPS серверов с TLS (добавляет security параметры в VLESS ссылку)
XUI_SERVERS_JSON=[{"url":"https://your-server.com:8444/path","username":"admin","password":"password","name":"Server1_VPN","inboundId":1,"maxClients":200,"subdomain":"vpn.your-server.com"},{"url":"http://local-server:8444/path","username":"admin","password":"password","name":"Server2_VPN","inboundId":3,"maxClients":200}]

# Sber Payment (если используется)
SBER_PHONE=+79001234567
SBER_RECIPIENT_NAME=Иван И.

# AI Configuration (DeepSeek/OpenAI)
DEEPSEEK_API_KEY=your_api_key_here
# Или для OpenAI:
# OPENAI_API_KEY=sk-...

# Security
ENCRYPTION_KEY=your_fernet_key_for_corp_api_keys
